{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "yanxu",
      "camelcase": "Yanxu",
      "scope": "source.yanxu",
      "path": ".",
      "file-types": ["yx"],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "1.1.18",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Yanxu programming language",
    "authors": [
      { "name": "Yanxu contributors" }
    ],
    "links": {
      "repository": "https://github.com/YanXuLang/yanxu"
    }
  },
  "bindings": {
    "c": true,
    "node": true,
    "rust": true
  }
}
